{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "figma": {
      "type": "http",
      "url": "${FIGMA_MCP_URL}"
    },
    "sentry": {
      "type": "http",
      "url": "${SENTRY_MCP_URL}"
    },
    "postman": {
      "type": "http",
      "url": "${POSTMAN_MCP_URL}"
    },
    "composio": {
      "type": "http",
      "url": "${COMPOSIO_MCP_URL}"
    }
  }
}
