    "nemotron": {"type": "stdio", "command": "uv", "args": ["run", "${ENGINEERING_OS_HOME}/scripts/nemotron-mcp-server.py"]},
    "slack": {"type": "http", "url": "${SLACK_MCP_URL}"},
    "linear": {"type": "http", "url": "${LINEAR_MCP_URL}"},
    "jira": {"type": "http", "url": "${JIRA_MCP_URL}"},
    "postgres": {"type": "http", "url": "${POSTGRES_MCP_URL}"},
    "google-drive": {"type": "http", "url": "${GOOGLE_DRIVE_MCP_URL}"},
    "google-sheets": {"type": "http", "url": "${GOOGLE_SHEETS_MCP_URL}"},
    "figma": {"type": "http", "url": "${FIGMA_MCP_URL}"},
    "sentry": {"type": "http", "url": "${SENTRY_MCP_URL}"},
    "postman": {"type": "http", "url": "${POSTMAN_MCP_URL}"},
    "composio": {"type": "http", "url": "${COMPOSIO_MCP_URL}"}
