{
  "mcpServers": {
    "context7": {"type": "http", "url": "https://mcp.context7.com/mcp"},
    "notion": {"type": "http", "url": "https://mcp.notion.com/mcp"},
    "stripe": {"type": "http", "url": "https://mcp.stripe.com"},
    "supabase": {"type": "http", "url": "https://mcp.supabase.com/mcp"},
